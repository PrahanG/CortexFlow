{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "https://cortexflow-backend-your-service-hash.a.run.app/api/v1/:path*"
    },
    {
      "source": "/(..*)",
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
